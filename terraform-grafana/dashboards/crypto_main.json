        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${DS_BIGQUERY}"
          },
          "editorMode": "code",
          "format": 1,
          "location": "",
          "project": "project-lambda-crypto",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  event_time AS Time,\r\n  symbol AS Symbol,\r\n  alert_type AS Alert_Type,\r\n  alert_message AS Message\r\nFROM `project-lambda-crypto.crypto_analytics_dataset.market_alerts`\r\nWHERE symbol IN (${symbol:singlequote})\r\n  -- 1. Lọc: Chỉ lấy tin nhắn trong vòng 15 phút qua\r\n  AND event_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 15 MINUTE)\r\n  -- 2. Kết hợp với bộ lọc thời gian của Grafana (nếu muốn)\r\n  AND $__timeFilter(event_time)\r\nORDER BY event_time DESC -- 3. Đưa tin mới nhất lên đầu",
          "refId": "A",
          "sql": {
