      "targets": [
        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${DS_BIGQUERY}"
          },
          "editorMode": "code",
          "format": 1,
          "location": "",
          "project": "project-lambda-crypto",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  window_start AS time,\r\n  open_price AS open,\r\n  high_price AS high,\r\n  low_price AS low,\r\n  close_price AS close,\r\n  volume AS volume,\r\n  \r\n  -- Nếu chọn VWAP thì hiện giá trị, không thì gán NULL\r\n  IF(STRPOS('${indicators:csv}', 'VWAP') > 0, VWAP, NULL) AS vwap,\r\n  \r\n  -- Tương tự với SMA20\r\n  IF(STRPOS('${indicators:csv}', 'SMA20') > 0, sma20, NULL) AS sma20,\r\n  \r\n  -- Tương tự với Dải Bollinger\r\n  IF(STRPOS('${indicators:csv}', 'BollingerBands') > 0, upper_band, NULL) AS upper_band,\r\n  IF(STRPOS('${indicators:csv}', 'BollingerBands') > 0, lower_band, NULL) AS lower_band\r\n\r\nFROM `project-lambda-crypto.crypto_analytics_dataset.candlestick_1min`\r\nWHERE symbol IN (${symbol:singlequote})\r\n  AND $__timeFilter(window_start)\r\nORDER BY time ASC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        },
        {
          "datasource": {
            "type": "grafana-bigquery-datasource",
            "uid": "${DS_BIGQUERY}"
          },
          "editorMode": "code",
          "format": 1,
          "location": "",
          "project": "project-lambda-crypto",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  a.event_time AS time,\r\n  \r\n  -- Logic: \r\n  -- 1. Nếu chọn 'None' -> Ẩn chấm (NULL).\r\n  -- 2. Nếu KHÔNG tick chọn 'Alerts' -> Ẩn chấm (NULL).\r\n  -- 3. Ngược lại mới hiện giá trị close_price để vẽ chấm.\r\n  IF(\r\n    STRPOS('${indicators:csv}', 'None') > 0 OR STRPOS('${indicators:csv}', 'Alerts') = 0, \r\n    NULL, \r\n    c.close_price\r\n  ) AS alert_dot,\r\n  \r\n  a.alert_type,\r\n  a.alert_message\r\nFROM `project-lambda-crypto.crypto_analytics_dataset.market_alerts` a\r\nJOIN `project-lambda-crypto.crypto_analytics_dataset.candlestick_1min` c\r\n  ON a.symbol = c.symbol \r\n  AND a.event_time BETWEEN c.window_start AND c.window_end\r\nWHERE a.symbol IN (${symbol:singlequote})\r\n  AND $__timeFilter(a.event_time)\r\nORDER BY time ASC",
          "refId": "B",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Candlestick & Volume Symbols (${symbol})",
      "transparent": true,
      "type": "candlestick"
    },
